import React, { useEffect, useState } from 'react';
import { useApp } from '../context/AppContext';
import {
  Users,
  CheckCircle,
  Clock,
  UserPlus,
  Map,
  ArrowUpRight,
  TrendingUp,
  Activity,
  Calendar
} from 'lucide-react';
import {
  BarChart,
  Bar,
  XAxis,
  YAxis,
  CartesianGrid,
  Tooltip,
  Legend,
  ResponsiveContainer,
  PieChart,
  Pie,
  Cell
} from 'recharts';
import { DashboardSkeleton } from '../components/Skeleton';

export const Dashboard: React.FC = () => {
  const { munsyiList, recentActivities, settings } = useApp();
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    // Simulate loading for the premium dashboard feel
    const timer = setTimeout(() => {
      setLoading(false);
    }, 800);
    return () => clearTimeout(timer);
  }, []);

  // Compute stats dynamically
  const totalMunsyi = munsyiList.length;
  const lulusMunsyi = munsyiList.filter((m) => m.status === 'Lulus').length;
  const belumLulusMunsyi = munsyiList.filter((m) => m.status === 'Belum Lulus').length;
  const permohonanBaharu = munsyiList.filter((m) => m.tahun === '2024' || m.tahun === '2026').length;
  const jumlahNegeri = new Set(munsyiList.map((m) => m.negeri)).size;

  // Prepare chart data 1: Munsyi by Bidang
  const bidangCounts = munsyiList.reduce((acc: Record<string, number>, curr) => {
    acc[curr.bidang] = (acc[curr.bidang] || 0) + 1;
    return acc;
  }, {});

  const chartDataBidang = Object.keys(bidangCounts).map((key) => ({
    name: key.length > 15 ? `${key.substring(0, 15)}...` : key,
    fullName: key,
    Jumlah: bidangCounts[key]
  }));

  // Prepare chart data 2: Munsyi by Status (Pie)
  const chartDataStatus = [
    { name: 'Lulus', value: lulusMunsyi, color: settings.primaryColor },
    { name: 'Belum Lulus', value: belumLulusMunsyi, color: '#E2E8F0' } // Slate-200 or custom amber
  ];

  // Prepare chart data 3: Munsyi by Negeri
  const negeriCounts = munsyiList.reduce((acc: Record<string, number>, curr) => {
    acc[curr.negeri] = (acc[curr.negeri] || 0) + 1;
    return acc;
  }, {});

  const chartDataNegeri = Object.keys(negeriCounts).map((key) => ({
    name: key,
    Jumlah: negeriCounts[key]
  })).sort((a, b) => b.Jumlah - a.Jumlah).slice(0, 5); // top 5

  const COLORS = [settings.primaryColor, '#F59E0B', '#10B981', '#EC4899', '#8B5CF6'];

  if (loading) {
    return <DashboardSkeleton />;
  }

  const statCards = [
    {
      id: 'stat-total',
      title: 'Jumlah Munsyi',
      value: totalMunsyi,
      icon: Users,
      bgColor: 'bg-blue-50 text-blue-600 dark:bg-blue-950/10 dark:text-blue-400',
      desc: 'Pendaftaran berdaftar'
    },
    {
      id: 'stat-lulus',
      title: 'Jumlah Lulus',
      value: lulusMunsyi,
      icon: CheckCircle,
      bgColor: 'bg-emerald-50 text-emerald-600 dark:bg-emerald-950/10 dark:text-emerald-400',
      desc: 'Munsyi Dewan sah'
    },
    {
      id: 'stat-belum',
      title: 'Belum Lulus',
      value: belumLulusMunsyi,
      icon: Clock,
      bgColor: 'bg-amber-50 text-amber-600 dark:bg-amber-950/10 dark:text-amber-400',
      desc: 'Menunggu kelulusan'
    },
    {
      id: 'stat-baharu',
      title: 'Permohonan Baharu',
      value: permohonanBaharu,
      icon: UserPlus,
      bgColor: 'bg-purple-50 text-purple-600 dark:bg-purple-950/10 dark:text-purple-400',
      desc: 'Sesi terkini (2024-2026)'
    },
    {
      id: 'stat-negeri',
      title: 'Jumlah Negeri',
      value: `${jumlahNegeri}/15`,
      icon: Map,
      bgColor: 'bg-indigo-50 text-indigo-600 dark:bg-indigo-950/10 dark:text-indigo-400',
      desc: 'Kawasan liputan'
    }
  ];

  return (
    <div id="dashboard-page" className="space-y-6">
      {/* Welcome Banner */}
      <div className="bg-gradient-to-r from-blue-600 to-indigo-700 dark:from-slate-800 dark:to-slate-900 rounded-2xl p-6 text-white shadow-md relative overflow-hidden">
        <div className="absolute right-0 bottom-0 opacity-10 pointer-events-none">
          <Activity className="w-64 h-64" />
        </div>
        <div className="relative z-10 space-y-2">
          <div className="inline-flex items-center gap-1 bg-white/10 text-white text-xs px-2.5 py-1 rounded-full font-semibold">
            <TrendingUp className="w-3.5 h-3.5" />
            <span>Sistem Maklumat SPMDM Live</span>
          </div>
          <h2 className="text-2xl font-bold tracking-tight">Selamat Datang, Osman bin Mansur</h2>
          <p className="text-blue-100 dark:text-slate-300 text-sm max-w-2xl font-medium leading-relaxed">
            Sistem pengurusan data munsyi ini membolehkan anda memantau status, pendaftaran munsyi mengikut kepakaran bidang dan negeri dengan pantas dan efisien.
          </p>
        </div>
      </div>

      {/* Stats Cards Grid */}
      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
        {statCards.map((card) => {
          const CardIcon = card.icon;
          return (
            <div
              key={card.id}
              id={card.id}
              className="bg-white dark:bg-slate-900 p-5 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.02)] hover:shadow-md transition-all group duration-300"
            >
              <div className="flex justify-between items-start">
                <span className="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wide">
                  {card.title}
                </span>
                <span className={`p-2.5 rounded-xl ${card.bgColor} group-hover:scale-105 transition-transform`}>
                  <CardIcon className="w-5 h-5" />
                </span>
              </div>
              <div className="mt-3">
                <h3 className="text-2xl font-black text-slate-800 dark:text-white tracking-tight">
                  {card.value}
                </h3>
                <p className="text-[11px] text-slate-400 dark:text-slate-500 mt-1 font-medium">
                  {card.desc}
                </p>
              </div>
            </div>
          );
        })}
      </div>

      {/* Charts Section */}
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {/* Bar Chart: Bidang */}
        <div className="lg:col-span-2 bg-white dark:bg-slate-900 p-6 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.02)] flex flex-col">
          <div className="flex justify-between items-center mb-6">
            <div>
              <h4 className="text-sm font-bold text-slate-800 dark:text-white">Statistik Mengikut Bidang Kepakaran</h4>
              <p className="text-xs text-slate-400 dark:text-slate-500">Agihan munsyi mengikut pengkhususan</p>
            </div>
            <div className="text-[10px] text-slate-400 font-bold bg-slate-50 dark:bg-slate-850 px-2 py-1 rounded border dark:border-slate-800">
              JUMLAH: {totalMunsyi}
            </div>
          </div>
          <div className="flex-1 min-h-[300px]">
            {chartDataBidang.length === 0 ? (
              <div className="h-full flex items-center justify-center text-slate-400 text-sm">
                Tiada data untuk dipaparkan.
              </div>
            ) : (
              <ResponsiveContainer width="100%" height="100%">
                <BarChart data={chartDataBidang} margin={{ top: 10, right: 10, left: -20, bottom: 5 }}>
                  <CartesianGrid strokeDasharray="3 3" vertical={false} stroke="#E2E8F0" className="dark:stroke-slate-800" />
                  <XAxis dataKey="name" stroke="#94A3B8" fontSize={10} tickLine={false} />
                  <YAxis stroke="#94A3B8" fontSize={10} tickLine={false} />
                  <Tooltip
                    contentStyle={{
                      backgroundColor: 'rgba(15, 23, 42, 0.95)',
                      borderRadius: '12px',
                      border: 'none',
                      color: '#fff',
                      fontSize: '12px'
                    }}
                    labelFormatter={(label, items) => {
                      return items[0]?.payload?.fullName || label;
                    }}
                  />
                  <Bar dataKey="Jumlah" fill={settings.primaryColor} radius={[6, 6, 0, 0]} barSize={36} />
                </BarChart>
              </ResponsiveContainer>
            )}
          </div>
        </div>

        {/* Pie Chart: Status Lulus */}
        <div className="bg-white dark:bg-slate-900 p-6 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.02)] flex flex-col">
          <h4 className="text-sm font-bold text-slate-800 dark:text-white mb-1">Status Kelulusan Munsyi</h4>
          <p className="text-xs text-slate-400 dark:text-slate-500 mb-6">Nisbah lulus berbanding belum lulus</p>

          <div className="flex-1 min-h-[220px] flex items-center justify-center relative">
            <ResponsiveContainer width="100%" height="100%">
              <PieChart>
                <Pie
                  data={chartDataStatus}
                  cx="50%"
                  cy="50%"
                  innerRadius={65}
                  outerRadius={85}
                  paddingAngle={5}
                  dataKey="value"
                >
                  <Cell fill={settings.primaryColor} />
                  <Cell fill="#E2E8F0" className="dark:fill-slate-800" />
                </Pie>
                <Tooltip
                  contentStyle={{
                    backgroundColor: 'rgba(15, 23, 42, 0.95)',
                    borderRadius: '12px',
                    border: 'none',
                    color: '#fff',
                    fontSize: '12px'
                  }}
                />
              </PieChart>
            </ResponsiveContainer>
            {/* Center Label */}
            <div className="absolute text-center">
              <span className="text-3xl font-black text-slate-800 dark:text-white tracking-tight">
                {Math.round((lulusMunsyi / (totalMunsyi || 1)) * 100)}%
              </span>
              <p className="text-[10px] text-slate-400 dark:text-slate-500 font-bold uppercase tracking-wider mt-0.5">
                Kadar Lulus
              </p>
            </div>
          </div>

          {/* Pie Legends */}
          <div className="grid grid-cols-2 gap-4 mt-4 pt-4 border-t border-slate-50 dark:border-slate-800">
            <div className="space-y-1">
              <div className="flex items-center gap-2">
                <span className="w-3 h-3 rounded-full" style={{ backgroundColor: settings.primaryColor }} />
                <span className="text-xs font-semibold text-slate-700 dark:text-slate-300">Lulus</span>
              </div>
              <p className="text-base font-extrabold text-slate-800 dark:text-white pl-5">{lulusMunsyi} orang</p>
            </div>
            <div className="space-y-1">
              <div className="flex items-center gap-2">
                <span className="w-3 h-3 rounded-full bg-slate-200 dark:bg-slate-800" />
                <span className="text-xs font-semibold text-slate-700 dark:text-slate-300">Belum Lulus</span>
              </div>
              <p className="text-base font-extrabold text-slate-800 dark:text-white pl-5">{belumLulusMunsyi} orang</p>
            </div>
          </div>
        </div>
      </div>

      {/* Bottom Grid: Top States & Recent Activities */}
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {/* Top States Distribution */}
        <div className="bg-white dark:bg-slate-900 p-6 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.02)]">
          <h4 className="text-sm font-bold text-slate-800 dark:text-white mb-1">Agihan Mengikut Negeri Utama</h4>
          <p className="text-xs text-slate-400 dark:text-slate-500 mb-5">5 negeri dengan pendaftaran tertinggi</p>

          <div className="space-y-4">
            {chartDataNegeri.map((state, index) => {
              const percentage = Math.round((state.Jumlah / totalMunsyi) * 100);
              return (
                <div key={state.name} className="space-y-1.5">
                  <div className="flex justify-between items-center text-xs font-medium">
                    <span className="text-slate-700 dark:text-slate-300">{state.name}</span>
                    <span className="text-slate-500 dark:text-slate-400">
                      {state.Jumlah} orang ({percentage}%)
                    </span>
                  </div>
                  <div className="w-full h-2 bg-slate-50 dark:bg-slate-850 rounded-full overflow-hidden">
                    <div
                      className="h-full rounded-full transition-all duration-500"
                      style={{
                        width: `${percentage}%`,
                        backgroundColor: COLORS[index % COLORS.length]
                      }}
                    />
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        {/* Recent Activities Feed */}
        <div className="lg:col-span-2 bg-white dark:bg-slate-900 p-6 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.02)]">
          <div className="flex justify-between items-center mb-5">
            <div>
              <h4 className="text-sm font-bold text-slate-800 dark:text-white">Aktiviti Pentadbiran Terkini</h4>
              <p className="text-xs text-slate-400 dark:text-slate-500">Log tindakan sistem masa-nyata</p>
            </div>
            <span className="p-2 bg-slate-50 dark:bg-slate-800 rounded-xl">
              <Activity className="w-4 h-4 text-slate-500" />
            </span>
          </div>

          <div className="relative border-l-2 border-slate-100 dark:border-slate-800 pl-4 ml-3 space-y-5">
            {recentActivities.slice(0, 4).map((act) => (
              <div key={act.id} className="relative">
                {/* Timeline Dot */}
                <span className="absolute -left-[23px] top-1 w-2.5 h-2.5 rounded-full border-2 border-white bg-blue-500 dark:border-slate-900" />
                <div className="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-1">
                  <div>
                    <p className="text-xs text-slate-500 dark:text-slate-400">
                      <span className="font-semibold text-slate-800 dark:text-slate-200">{act.user}</span>{' '}
                      {act.action}
                    </p>
                    <p className="text-[11px] text-slate-400 dark:text-slate-500 font-medium mt-0.5">{act.detail}</p>
                  </div>
                  <span className="text-[10px] text-slate-400 dark:text-slate-500 font-bold whitespace-nowrap bg-slate-50 dark:bg-slate-850 px-2 py-0.5 rounded border dark:border-slate-800">
                    {act.time}
                  </span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  );
};
