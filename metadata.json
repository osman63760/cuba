import React, { useState, useRef } from 'react';
import { useApp } from '../context/AppContext';
import { Munsyi } from '../types';
import { SENARAI_NEGERI, SENARAI_BIDANG } from '../data/munsyiData';
import {
  FileUp,
  FileSpreadsheet,
  CheckCircle2,
  AlertCircle,
  RefreshCw,
  Trash2,
  Database,
  Eye,
  Download
} from 'lucide-react';

// Sample preview records
const MOCK_PREVIEW_RECORDS: Omit<Munsyi, 'id'>[] = [
  {
    nama: 'Dr. Zulkifli bin Mohamad Al-Bakri',
    noKP: '690116-09-5111',
    negeri: 'Terengganu',
    bidang: 'Sastera Kebangsaan',
    status: 'Lulus',
    tahun: '2024'
  },
  {
    nama: 'Puan Halimah binti Sadique',
    noKP: '740822-01-5224',
    negeri: 'Johor',
    bidang: 'Tatabahasa',
    status: 'Lulus',
    tahun: '2023'
  },
  {
    nama: 'Encik Tan Boon Heong',
    noKP: '840211-02-5367',
    negeri: 'Kedah',
    bidang: 'Seni Pengacaraan',
    status: 'Belum Lulus',
    tahun: '2025'
  },
  {
    nama: 'Cik Shamini a/p Selvaraju',
    noKP: '910930-14-5422',
    negeri: 'WP Kuala Lumpur',
    bidang: 'Terjemahan',
    status: 'Lulus',
    tahun: '2022'
  },
  {
    nama: 'Dr. Jacklon bin Gimbun',
    noKP: '801205-12-6113',
    negeri: 'Sabah',
    bidang: 'Peristilahan & Leksikografi',
    status: 'Lulus',
    tahun: '2021'
  }
];

export const ImportData: React.FC = () => {
  const { importBulkData, settings, addToast } = useApp();
  const [dragActive, setDragActive] = useState(false);
  const [file, setFile] = useState<File | null>(null);
  const [status, setStatus] = useState<'idle' | 'parsing' | 'preview' | 'imported'>('idle');
  const [importCount] = useState(120); // Always simulate 120 records as requested
  const fileInputRef = useRef<HTMLInputElement>(null);

  const handleDrag = (e: React.DragEvent) => {
    e.preventDefault();
    e.stopPropagation();
    if (e.type === 'dragenter' || e.type === 'dragover') {
      setDragActive(true);
    } else if (e.type === 'dragleave') {
      setDragActive(false);
    }
  };

  const processFile = (selectedFile: File) => {
    const ext = selectedFile.name.split('.').pop()?.toLowerCase();
    if (ext !== 'csv' && ext !== 'xlsx') {
      addToast('Format fail tidak disokong! Sila gunakan fail .csv atau .xlsx sahaja.', 'error');
      return;
    }

    setFile(selectedFile);
    setStatus('parsing');

    // Simulate standard file parsing/processing delay of 1.5 seconds
    setTimeout(() => {
      setStatus('preview');
      addToast(`Analisis fail ${selectedFile.name} selesai. 120 rekod ditemui!`, 'info');
    }, 1500);
  };

  const handleDrop = (e: React.DragEvent) => {
    e.preventDefault();
    e.stopPropagation();
    setDragActive(false);

    if (e.dataTransfer.files && e.dataTransfer.files[0]) {
      processFile(e.dataTransfer.files[0]);
    }
  };

  const handleFileChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    if (e.target.files && e.target.files[0]) {
      processFile(e.target.files[0]);
    }
  };

  const onButtonClick = () => {
    fileInputRef.current?.click();
  };

  const handleReset = () => {
    setFile(null);
    setStatus('idle');
    if (fileInputRef.current) fileInputRef.current.value = '';
    addToast('Import data telah set semula.', 'info');
  };

  const handleImportExecute = () => {
    if (!file) return;

    setStatus('parsing');

    // Simulate bulk database integration
    setTimeout(() => {
      // Programmatically generate some realistic bulk records to actually inject into context
      // This will make the dashboard numbers increase!
      const bulkToInsert: Munsyi[] = [];

      // Add our mock preview records first
      MOCK_PREVIEW_RECORDS.forEach((rec, idx) => {
        bulkToInsert.push({
          id: `IMP-${100 + idx}`,
          nama: rec.nama,
          noKP: rec.noKP,
          negeri: rec.negeri,
          bidang: rec.bidang,
          status: rec.status,
          tahun: rec.tahun
        });
      });

      // Generate supplementary dummy items to total up to 15 tangible new records in DB
      for (let i = 5; i < 15; i++) {
        const rNeg = SENARAI_NEGERI[i % SENARAI_NEGERI.length];
        const rBid = SENARAI_BIDANG[i % SENARAI_BIDANG.length];
        const isLulus = i % 3 !== 0; // 66% lulus rate
        bulkToInsert.push({
          id: `IMP-${100 + i}`,
          nama: `Munsyi Import #${i + 1} (${rNeg})`,
          noKP: `8${i}0512-14-${5000 + i}`,
          negeri: rNeg,
          bidang: rBid,
          status: isLulus ? 'Lulus' : 'Belum Lulus',
          tahun: '2024'
        });
      }

      importBulkData(bulkToInsert);
      setStatus('imported');
      addToast(`Kemasukan data berjaya! ${importCount} rekod telah didaftarkan ke pangkalan data.`, 'success');
    }, 1800);
  };

  return (
    <div id="import-page" className="space-y-6">
      <div>
        <h2 className="text-xl font-bold text-slate-950 dark:text-white">Import Data Munsyi Dewan</h2>
        <p className="text-xs text-slate-500 dark:text-slate-400">
          Muat naik senarai munsyi secara pukal menggunakan fail hamparan elektronik (Spreadsheet)
        </p>
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {/* Upload Zone & Guide */}
        <div className="lg:col-span-1 space-y-6">
          {/* Upload Card */}
          <div className="bg-white dark:bg-slate-900 p-6 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.02)] flex flex-col h-full justify-between">
            <div className="space-y-4">
              <h4 className="text-xs font-bold text-slate-800 dark:text-white uppercase tracking-wider">
                Muat Naik Fail
              </h4>

              {status === 'idle' && (
                <div
                  id="drop-zone"
                  onDragEnter={handleDrag}
                  onDragOver={handleDrag}
                  onDragLeave={handleDrag}
                  onDrop={handleDrop}
                  className={`border-2 border-dashed rounded-3xl p-6 text-center flex flex-col items-center justify-center min-h-[220px] transition-all cursor-pointer ${
                    dragActive
                      ? 'border-blue-500 bg-blue-50/50 dark:bg-blue-950/10'
                      : 'border-slate-200 hover:border-blue-400 dark:border-slate-800 dark:hover:border-slate-700 bg-slate-50/50 dark:bg-slate-950/20'
                  }`}
                  onClick={onButtonClick}
                >
                  <input
                    ref={fileInputRef}
                    id="import-file-input"
                    type="file"
                    className="hidden"
                    accept=".csv, .xlsx"
                    onChange={handleFileChange}
                  />
                  <div className="p-3 bg-white dark:bg-slate-800 rounded-xl shadow-xs text-blue-500 mb-3">
                    <FileUp className="w-6 h-6" />
                  </div>
                  <h5 className="text-xs font-bold text-slate-700 dark:text-slate-300">
                    Seret & Letak fail di sini
                  </h5>
                  <p className="text-[10px] text-slate-400 dark:text-slate-500 mt-1">
                    atau klik untuk pilih fail dari storan anda
                  </p>
                  <div className="flex gap-2 mt-4 text-[9px] font-bold uppercase tracking-wider text-slate-400">
                    <span className="px-1.5 py-0.5 bg-slate-100 dark:bg-slate-800 rounded">CSV</span>
                    <span className="px-1.5 py-0.5 bg-slate-100 dark:bg-slate-800 rounded">XLSX</span>
                  </div>
                </div>
              )}

              {status === 'parsing' && (
                <div className="border border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-950/10 rounded-3xl p-6 flex flex-col items-center justify-center min-h-[220px]">
                  <RefreshCw className="w-8 h-8 text-blue-500 animate-spin mb-3" />
                  <h5 className="text-xs font-bold text-slate-700 dark:text-slate-300">
                    Memproses & Menganalisis Fail
                  </h5>
                  <p className="text-[10px] text-slate-400 dark:text-slate-500 mt-1">
                    Mengekstrak baris data dan menjalankan validasi integriti...
                  </p>
                </div>
              )}

              {(status === 'preview' || status === 'imported') && file && (
                <div className="border border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-950/10 rounded-3xl p-5 space-y-4">
                  <div className="flex items-center gap-3">
                    <div className="p-2.5 bg-emerald-500 text-white rounded-xl shadow-sm">
                      <FileSpreadsheet className="w-5 h-5" />
                    </div>
                    <div className="min-w-0 flex-1">
                      <h5 className="text-xs font-bold text-slate-800 dark:text-slate-200 truncate">
                        {file.name}
                      </h5>
                      <p className="text-[10px] text-slate-400 dark:text-slate-500">
                        {(file.size / 1024).toFixed(1)} KB • Sedia untuk diimport
                      </p>
                    </div>
                  </div>

                  {status === 'preview' ? (
                    <div className="p-3 bg-blue-50/80 border border-blue-100 rounded-xl text-[11px] leading-relaxed text-blue-800 dark:bg-slate-850 dark:border-slate-800 dark:text-blue-300 flex items-start gap-2">
                      <CheckCircle2 className="w-4.5 h-4.5 text-emerald-500 shrink-0 mt-0.5" />
                      <div>
                        <span className="font-bold">{importCount} rekod sedia untuk diimport.</span>
                        <p className="mt-0.5">Semua data didapati bersih dan mematuhi skema munsyi.</p>
                      </div>
                    </div>
                  ) : (
                    <div className="p-3 bg-emerald-50/80 border border-emerald-100 rounded-xl text-[11px] leading-relaxed text-emerald-800 dark:bg-slate-850 dark:border-slate-800 dark:text-emerald-400 flex items-start gap-2">
                      <CheckCircle2 className="w-4.5 h-4.5 text-emerald-500 shrink-0" />
                      <div>
                        <span className="font-bold">Selesai Diimport!</span>
                        <p className="mt-0.5">Semua rekod telah berjaya diintegrasikan ke pangkalan data utama.</p>
                      </div>
                    </div>
                  )}
                </div>
              )}
            </div>

            {/* Action Buttons Footer */}
            <div className="flex gap-2.5 mt-6 pt-4 border-t border-slate-100 dark:border-slate-800">
              {status === 'preview' && (
                <>
                  <button
                    id="btn-import-reset"
                    onClick={handleReset}
                    className="flex-1 py-2.5 text-xs font-semibold text-rose-600 hover:text-rose-700 hover:bg-rose-50 dark:text-rose-400 dark:hover:bg-rose-950/20 rounded-xl transition-all flex items-center justify-center gap-1.5 border border-rose-100 dark:border-rose-950/30"
                  >
                    <Trash2 className="w-4 h-4" />
                    <span>Batal</span>
                  </button>
                  <button
                    id="btn-import-execute"
                    onClick={handleImportExecute}
                    className="flex-1 py-2.5 text-xs font-semibold text-white rounded-xl shadow-md transition-all flex items-center justify-center gap-1.5"
                    style={{
                      backgroundColor: settings.primaryColor,
                      boxShadow: `0 4px 12px -3px ${settings.primaryColor}50`
                    }}
                  >
                    <Database className="w-4 h-4" />
                    <span>Import Sekarang</span>
                  </button>
                </>
              )}

              {status === 'imported' && (
                <button
                  id="btn-import-done-reset"
                  onClick={handleReset}
                  className="w-full py-2.5 text-xs font-semibold bg-slate-100 hover:bg-slate-200 text-slate-700 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700 rounded-xl transition-all flex items-center justify-center gap-2"
                >
                  <RefreshCw className="w-4 h-4" />
                  <span>Import Fail Baharu</span>
                </button>
              )}
            </div>
          </div>
        </div>

        {/* Preview Data Table */}
        <div className="lg:col-span-2">
          <div className="bg-white dark:bg-slate-900 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.02)] p-6 h-full flex flex-col justify-between">
            <div className="space-y-4">
              <div className="flex justify-between items-center">
                <div>
                  <h4 className="text-xs font-bold text-slate-800 dark:text-white uppercase tracking-wider">
                    Pratinjau Data (Preview)
                  </h4>
                  <p className="text-[10px] text-slate-400 dark:text-slate-500 mt-0.5">
                    Memaparkan 5 sampel baris pertama fail terpilih
                  </p>
                </div>
                <span className="inline-flex items-center gap-1 text-[10px] font-bold text-blue-600 bg-blue-50 dark:bg-blue-950/10 dark:text-blue-400 px-2 py-1 rounded">
                  <Eye className="w-3.5 h-3.5" />
                  <span>SAMPEL</span>
                </span>
              </div>

              {status === 'idle' || status === 'parsing' ? (
                <div className="flex-1 border border-slate-200 dark:border-slate-800/80 rounded-3xl py-12 flex flex-col items-center justify-center text-center text-slate-400">
                  <FileSpreadsheet className="w-10 h-10 text-slate-300 mb-3" />
                  <h5 className="text-xs font-bold text-slate-700 dark:text-slate-400">
                    Pratinjau tidak tersedia
                  </h5>
                  <p className="text-[10px] text-slate-400 dark:text-slate-500 max-w-xs mt-1">
                    Sila muat naik fail mengikut skema Excel/CSV yang sah untuk memaparkan sampel data
                  </p>
                </div>
              ) : (
                <div className="border border-slate-100 dark:border-slate-800 rounded-xl overflow-hidden">
                  <div className="overflow-x-auto">
                    <table id="import-preview-table" className="w-full text-left border-collapse text-xs">
                      <thead>
                        <tr className="bg-slate-50 dark:bg-slate-950/40 text-slate-400 dark:text-slate-500 text-[10px] font-bold uppercase tracking-wider border-b border-slate-100 dark:border-slate-800">
                          <th className="px-4 py-3">Nama Munsyi</th>
                          <th className="px-4 py-3">No. KP</th>
                          <th className="px-4 py-3">Negeri</th>
                          <th className="px-4 py-3">Bidang</th>
                          <th className="px-4 py-3 text-center">Tahun</th>
                          <th className="px-4 py-3 text-center">Status</th>
                        </tr>
                      </thead>
                      <tbody className="divide-y divide-slate-100 dark:divide-slate-800">
                        {MOCK_PREVIEW_RECORDS.map((row, idx) => {
                          const isLulus = row.status === 'Lulus';
                          return (
                            <tr key={idx} className="hover:bg-slate-50/40 dark:hover:bg-slate-850/10 transition-colors">
                              <td className="px-4 py-3 font-semibold text-slate-700 dark:text-slate-300">
                                {row.nama}
                              </td>
                              <td className="px-4 py-3 font-mono text-slate-500 dark:text-slate-400">
                                {row.noKP}
                              </td>
                              <td className="px-4 py-3 text-slate-600 dark:text-slate-300 font-medium">
                                {row.negeri}
                              </td>
                              <td className="px-4 py-3 text-slate-500 dark:text-slate-400">
                                {row.bidang}
                              </td>
                              <td className="px-4 py-3 text-center font-bold text-slate-600 dark:text-slate-300">
                                {row.tahun}
                              </td>
                              <td className="px-4 py-3 text-center">
                                <span
                                  className={`inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[9px] font-bold ${
                                    isLulus
                                      ? 'bg-emerald-50 text-emerald-700 dark:bg-emerald-950/20 dark:text-emerald-400'
                                      : 'bg-amber-50 text-amber-700 dark:bg-amber-950/20 dark:text-amber-400'
                                  }`}
                                >
                                  {row.status}
                                </span>
                              </td>
                            </tr>
                          );
                        })}
                      </tbody>
                    </table>
                  </div>
                  <div className="p-3 bg-slate-50/50 dark:bg-slate-950/20 text-center text-[10px] font-bold text-slate-400 border-t border-slate-100 dark:border-slate-800">
                    + {importCount - 5} rekod lagi dalam fail ini...
                  </div>
                </div>
              )}
            </div>

            {/* Template Download / Guide */}
            <div className="mt-8 pt-4 border-t border-slate-100 dark:border-slate-800 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs">
              <div className="flex items-start gap-2 text-slate-500 dark:text-slate-400">
                <AlertCircle className="w-4 h-4 text-slate-400 shrink-0 mt-0.5" />
                <span className="leading-relaxed">
                  Pastikan lajur fail adalah: **Nama**, **NoKP**, **Negeri**, **Bidang**, **Status**, **Tahun**
                </span>
              </div>
              <button
                id="btn-download-template"
                onClick={() => {
                  addToast('Memuat turun fail templat SPMDM...', 'info');
                }}
                className="inline-flex items-center gap-1.5 text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300 font-bold transition-all shrink-0 cursor-pointer"
              >
                <Download className="w-4 h-4" />
                <span>Muat Turun Templat (.xlsx)</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
};
