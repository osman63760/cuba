import React, { useState } from 'react';
import { useApp } from '../context/AppContext';
import {
  User,
  Mail,
  Briefcase,
  Phone,
  Lock,
  Camera,
  Save,
  KeyRound,
  ShieldAlert
} from 'lucide-react';

export const ProfilAdmin: React.FC = () => {
  const { profil, updateProfil, settings, addToast } = useApp();

  // Profile Form States
  const [nama, setNama] = useState(profil.nama);
  const [emel, setEmel] = useState(profil.emel);
  const [jawatan, setJawatan] = useState(profil.jawatan);
  const [telefon, setTelefon] = useState(profil.telefon);
  const [avatar, setAvatar] = useState(profil.avatar);

  // Password Form States
  const [currentPassword, setCurrentPassword] = useState('');
  const [newPassword, setNewPassword] = useState('');
  const [confirmPassword, setConfirmPassword] = useState('');

  const handleUpdateProfile = (e: React.FormEvent) => {
    e.preventDefault();
    if (!nama.trim() || !emel.trim() || !jawatan.trim() || !telefon.trim()) {
      addToast('Sila lengkapkan semua maklumat profil!', 'error');
      return;
    }

    // Basic email format validation
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emel.trim())) {
      addToast('Format emel tidak sah!', 'warning');
      return;
    }

    updateProfil({
      nama: nama.trim(),
      emel: emel.trim(),
      jawatan: jawatan.trim(),
      telefon: telefon.trim(),
      avatar: avatar.trim()
    });
  };

  const handleChangePassword = (e: React.FormEvent) => {
    e.preventDefault();
    if (!currentPassword || !newPassword || !confirmPassword) {
      addToast('Sila isi semua medan kata laluan!', 'error');
      return;
    }

    if (currentPassword !== 'admin123') {
      addToast('Kata laluan semasa salah!', 'error');
      return;
    }

    if (newPassword.length < 6) {
      addToast('Kata laluan baharu mestilah sekurang-kurangnya 6 aksara!', 'warning');
      return;
    }

    if (newPassword !== confirmPassword) {
      addToast('Sahkan kata laluan baharu tidak sepadan!', 'error');
      return;
    }

    addToast('Kata laluan berjaya ditukar!', 'success');
    setCurrentPassword('');
    setNewPassword('');
    setConfirmPassword('');
  };

  // Preset avatars for demonstration
  const AVATAR_PRESETS = [
    'https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=250&auto=format&fit=crop',
    'https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?q=80&w=250&auto=format&fit=crop',
    'https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?q=80&w=250&auto=format&fit=crop',
    'https://images.unsplash.com/photo-1580489944761-15a19d654956?q=80&w=250&auto=format&fit=crop'
  ];

  return (
    <div id="profile-page" className="space-y-6">
      <div>
        <h2 className="text-xl font-bold text-slate-950 dark:text-white">Profil Pentadbir</h2>
        <p className="text-xs text-slate-500 dark:text-slate-400">
          Urus maklumat peribadi pentadbir sistem dan kemas kini kata laluan keselamatan
        </p>
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {/* Left Side: Avatar & Bio display card */}
        <div className="lg:col-span-1 space-y-6">
          <div className="bg-white dark:bg-slate-900 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.02)] p-6 flex flex-col items-center text-center">
            {/* Avatar container */}
            <div className="relative group w-28 h-28 rounded-2xl overflow-hidden shadow-lg border-2 border-slate-100 dark:border-slate-800 mb-5">
              <img
                src={avatar}
                alt={nama}
                referrerPolicy="no-referrer"
                className="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
              <div className="absolute inset-0 bg-black/45 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center text-white pointer-events-none">
                <Camera className="w-5 h-5" />
              </div>
            </div>

            <h3 className="text-base font-bold text-slate-800 dark:text-white">{nama}</h3>
            <p className="text-xs text-slate-400 dark:text-slate-500 font-semibold uppercase tracking-wider mt-1">{jawatan}</p>

            <div className="h-0.5 w-12 bg-slate-50 dark:bg-slate-800 rounded-full my-4" />

            {/* Quick stats / contacts */}
            <div className="w-full space-y-3.5 text-xs text-left">
              <div className="flex items-center gap-3 text-slate-600 dark:text-slate-300">
                <Mail className="w-4 h-4 text-slate-400 shrink-0" />
                <span className="truncate font-medium">{emel}</span>
              </div>
              <div className="flex items-center gap-3 text-slate-600 dark:text-slate-300">
                <Phone className="w-4 h-4 text-slate-400 shrink-0" />
                <span className="font-medium">{telefon}</span>
              </div>
              <div className="flex items-center gap-3 text-slate-600 dark:text-slate-300">
                <Briefcase className="w-4 h-4 text-slate-400 shrink-0" />
                <span className="font-medium">{jawatan}</span>
              </div>
            </div>

            {/* Avatar Selector Presets */}
            <div className="w-full pt-5 border-t border-slate-50 dark:border-slate-800 mt-5 space-y-2">
              <span className="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider block text-left">
                Pilih Gambar Avatar
              </span>
              <div className="flex gap-2.5 justify-start">
                {AVATAR_PRESETS.map((avUrl, index) => (
                  <button
                    key={index}
                    id={`btn-avatar-preset-${index}`}
                    type="button"
                    onClick={() => setAvatar(avUrl)}
                    className={`w-9 h-9 rounded-lg overflow-hidden border-2 transition-transform hover:scale-105 ${
                      avatar === avUrl ? 'border-blue-500 shadow-sm' : 'border-slate-100 dark:border-slate-800'
                    }`}
                  >
                    <img src={avUrl} alt="Avatar Preset" className="w-full h-full object-cover" referrerPolicy="no-referrer" />
                  </button>
                ))}
              </div>
            </div>
          </div>
        </div>

        {/* Right Side: Update Profile and Change Password tabs/forms */}
        <div className="lg:col-span-2 space-y-6">
          {/* Update Profile Form */}
          <div className="bg-white dark:bg-slate-900 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.02)] p-6">
            <div className="flex items-center gap-2 pb-3 border-b border-slate-50 dark:border-slate-800 mb-5">
              <User className="w-4.5 h-4.5 text-blue-500" />
              <h4 className="text-sm font-bold text-slate-800 dark:text-white">Kemaskini Maklumat Profil</h4>
            </div>

            <form onSubmit={handleUpdateProfile} className="space-y-4">
              <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {/* Nama Penuh */}
                <div className="space-y-1">
                  <label className="text-[11px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wide">
                    Nama Penuh
                  </label>
                  <input
                    id="profile-nama"
                    type="text"
                    required
                    value={nama}
                    onChange={(e) => setNama(e.target.value)}
                    className="w-full px-3 py-2.5 text-xs bg-slate-50 dark:bg-slate-950/40 border border-slate-200 dark:border-slate-800 rounded-xl text-slate-800 dark:text-slate-200 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500 font-medium"
                  />
                </div>

                {/* Emel */}
                <div className="space-y-1">
                  <label className="text-[11px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wide">
                    Alamat Emel Rasmi
                  </label>
                  <input
                    id="profile-emel"
                    type="email"
                    required
                    value={emel}
                    onChange={(e) => setEmel(e.target.value)}
                    className="w-full px-3 py-2.5 text-xs bg-slate-50 dark:bg-slate-950/40 border border-slate-200 dark:border-slate-800 rounded-xl text-slate-800 dark:text-slate-200 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500 font-medium"
                  />
                </div>

                {/* Jawatan */}
                <div className="space-y-1">
                  <label className="text-[11px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wide">
                    Jawatan & Gred
                  </label>
                  <input
                    id="profile-jawatan"
                    type="text"
                    required
                    value={jawatan}
                    onChange={(e) => setJawatan(e.target.value)}
                    className="w-full px-3 py-2.5 text-xs bg-slate-50 dark:bg-slate-950/40 border border-slate-200 dark:border-slate-800 rounded-xl text-slate-800 dark:text-slate-200 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500 font-medium"
                  />
                </div>

                {/* Telefon */}
                <div className="space-y-1">
                  <label className="text-[11px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wide">
                    No. Telefon Bimbit
                  </label>
                  <input
                    id="profile-telefon"
                    type="text"
                    required
                    value={telefon}
                    onChange={(e) => setTelefon(e.target.value)}
                    className="w-full px-3 py-2.5 text-xs bg-slate-50 dark:bg-slate-950/40 border border-slate-200 dark:border-slate-800 rounded-xl text-slate-800 dark:text-slate-200 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500 font-medium"
                  />
                </div>
              </div>

              <div className="flex justify-end pt-3">
                <button
                  id="profile-update-btn"
                  type="submit"
                  className="px-4.5 py-2.5 text-xs font-semibold text-white rounded-xl shadow-md hover:scale-[1.02] cursor-pointer transition-all flex items-center gap-1.5"
                  style={{
                    backgroundColor: settings.primaryColor,
                    boxShadow: `0 4px 12px -3px ${settings.primaryColor}50`
                  }}
                >
                  <Save className="w-4 h-4" />
                  <span>Kemaskini Profil</span>
                </button>
              </div>
            </form>
          </div>

          {/* Change Password Form */}
          <div className="bg-white dark:bg-slate-900 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.02)] p-6">
            <div className="flex items-center gap-2 pb-3 border-b border-slate-50 dark:border-slate-800 mb-5">
              <KeyRound className="w-4.5 h-4.5 text-blue-500" />
              <h4 className="text-sm font-bold text-slate-800 dark:text-white">Tukar Kata Laluan Keselamatan</h4>
            </div>

            <form onSubmit={handleChangePassword} className="space-y-4">
              <div className="grid grid-cols-1 sm:grid-cols-3 gap-4">
                {/* Kata Laluan Semasa */}
                <div className="space-y-1">
                  <label className="text-[11px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wide">
                    Kata Laluan Semasa
                  </label>
                  <input
                    id="profile-psw-current"
                    type="password"
                    required
                    value={currentPassword}
                    onChange={(e) => setCurrentPassword(e.target.value)}
                    placeholder="cth: admin123"
                    className="w-full px-3 py-2.5 text-xs bg-slate-50 dark:bg-slate-950/40 border border-slate-200 dark:border-slate-800 rounded-xl text-slate-800 dark:text-slate-200 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500 font-medium"
                  />
                </div>

                {/* Kata Laluan Baharu */}
                <div className="space-y-1">
                  <label className="text-[11px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wide">
                    Kata Laluan Baharu
                  </label>
                  <input
                    id="profile-psw-new"
                    type="password"
                    required
                    value={newPassword}
                    onChange={(e) => setNewPassword(e.target.value)}
                    placeholder="Minimum 6 aksara"
                    className="w-full px-3 py-2.5 text-xs bg-slate-50 dark:bg-slate-950/40 border border-slate-200 dark:border-slate-800 rounded-xl text-slate-800 dark:text-slate-200 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500 font-medium"
                  />
                </div>

                {/* Sahkan Kata Laluan Baharu */}
                <div className="space-y-1">
                  <label className="text-[11px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wide">
                    Sahkan Kata Laluan Baharu
                  </label>
                  <input
                    id="profile-psw-confirm"
                    type="password"
                    required
                    value={confirmPassword}
                    onChange={(e) => setConfirmPassword(e.target.value)}
                    placeholder="Sahkan semula"
                    className="w-full px-3 py-2.5 text-xs bg-slate-50 dark:bg-slate-950/40 border border-slate-200 dark:border-slate-800 rounded-xl text-slate-800 dark:text-slate-200 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/10 focus:border-blue-500 font-medium"
                  />
                </div>
              </div>

              {/* Password info notice */}
              <div className="flex items-start gap-2 bg-slate-50 dark:bg-slate-950/40 p-3.5 rounded-xl border border-slate-100 dark:border-slate-800 text-[10px] text-slate-400 leading-relaxed font-medium">
                <ShieldAlert className="w-4 h-4 text-slate-400 mt-0.5 shrink-0" />
                <span>
                  Pastikan kata laluan baharu anda mengandungi gabungan huruf dan nombor untuk mengekalkan tahap keselamatan sistem pentadbiran yang tinggi.
                </span>
              </div>

              <div className="flex justify-end pt-2">
                <button
                  id="profile-change-password-btn"
                  type="submit"
                  className="px-4.5 py-2.5 text-xs font-semibold text-white rounded-xl shadow-md hover:scale-[1.02] cursor-pointer transition-all flex items-center gap-1.5"
                  style={{
                    backgroundColor: settings.primaryColor,
                    boxShadow: `0 4px 12px -3px ${settings.primaryColor}50`
                  }}
                >
                  <Lock className="w-4 h-4" />
                  <span>Tukar Kata Laluan</span>
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  );
};
